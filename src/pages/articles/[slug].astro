---
import { marked } from "marked";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchPublishedArticleBySlug, fetchPublishedArticles } from "@/lib/supabase";

export async function getStaticPaths() {
  const articles = await fetchPublishedArticles();
  return articles.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
if (!slug) {
  throw new Error("slug が未定義です");
}

let article: Awaited<ReturnType<typeof fetchPublishedArticleBySlug>>;
let loadError: string | null = null;
try {
  article = await fetchPublishedArticleBySlug(slug);
} catch (e) {
  loadError = e instanceof Error ? e.message : String(e);
  article = null;
}

if (!loadError && !article) {
  return Astro.redirect("/404");
}
const pageTitle = article?.seo_title || article?.title || "記事";
const metaDesc = article?.meta_description || article?.excerpt || undefined;
const html = article ? await marked.parse(article.body_markdown) : "";
---
<BaseLayout title={pageTitle} description={metaDesc}>
  {
    loadError ? (
      <p role="alert">{loadError}</p>
    ) : article ? (
      <>
        <p>
          <a href="/articles">← 一覧</a>
        </p>
        <article>
          <h1>{article.title}</h1>
          <p>
            <small>
              {article.category} · 更新 {article.updated_at}
            </small>
          </p>
          <div class="prose" set:html={html} />
        </article>
      </>
    ) : null
  }
</BaseLayout>
